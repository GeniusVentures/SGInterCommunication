#pragma once

// Simple message definitions for minimal build without Protobuf
// This replaces the protobuf-generated headers when building without dependencies

#include <string>
#include <vector>
#include <cstdint>
#include <memory>

namespace sgipc {
namespace simple {

enum class MessageType : uint8_t {
    HEARTBEAT = 0,
    PORT_REQUEST = 1,
    PORT_RESPONSE = 2,
    DISCOVERY_ANNOUNCEMENT = 3,
    DATA_MESSAGE = 4
};

// Simple message structure
struct SimpleMessage {
    MessageType type;
    std::string sender_id;
    std::string payload;
    uint64_t timestamp;
    
    SimpleMessage() : type(MessageType::HEARTBEAT), timestamp(0) {}
    
    SimpleMessage(MessageType t, const std::string& id, const std::string& data) 
        : type(t), sender_id(id), payload(data), timestamp(0) {}
    
    // Simple serialization
    std::vector<uint8_t> serialize() const {
        std::vector<uint8_t> result;
        
        // Type (1 byte)
        result.push_back(static_cast<uint8_t>(type));
        
        // Timestamp (8 bytes)
        for (int i = 0; i < 8; ++i) {
            result.push_back((timestamp >> (i * 8)) & 0xFF);
        }
        
        // Sender ID length (4 bytes) + data
        uint32_t sender_len = static_cast<uint32_t>(sender_id.length());
        for (int i = 0; i < 4; ++i) {
            result.push_back((sender_len >> (i * 8)) & 0xFF);
        }
        result.insert(result.end(), sender_id.begin(), sender_id.end());
        
        // Payload length (4 bytes) + data
        uint32_t payload_len = static_cast<uint32_t>(payload.length());
        for (int i = 0; i < 4; ++i) {
            result.push_back((payload_len >> (i * 8)) & 0xFF);
        }
        result.insert(result.end(), payload.begin(), payload.end());
        
        return result;
    }
    
    // Simple deserialization
    static SimpleMessage deserialize(const std::vector<uint8_t>& data) {
        SimpleMessage msg;
        
        if (data.size() < 17) { // Minimum size: 1 + 8 + 4 + 4 = 17 bytes
            return msg;
        }
        
        size_t offset = 0;
        
        // Type
        msg.type = static_cast<MessageType>(data[offset++]);
        
        // Timestamp
        msg.timestamp = 0;
        for (int i = 0; i < 8; ++i) {
            msg.timestamp |= (static_cast<uint64_t>(data[offset++]) << (i * 8));
        }
        
        // Sender ID
        uint32_t sender_len = 0;
        for (int i = 0; i < 4; ++i) {
            sender_len |= (static_cast<uint32_t>(data[offset++]) << (i * 8));
        }
        
        if (offset + sender_len > data.size()) {
            return SimpleMessage(); // Invalid data
        }
        
        msg.sender_id = std::string(data.begin() + offset, data.begin() + offset + sender_len);
        offset += sender_len;
        
        // Payload
        if (offset + 4 > data.size()) {
            return msg; // No payload
        }
        
        uint32_t payload_len = 0;
        for (int i = 0; i < 4; ++i) {
            payload_len |= (static_cast<uint32_t>(data[offset++]) << (i * 8));
        }
        
        if (offset + payload_len > data.size()) {
            return msg; // Invalid payload
        }
        
        msg.payload = std::string(data.begin() + offset, data.begin() + offset + payload_len);
        
        return msg;
    }
};

// Helper functions
inline SimpleMessage createHeartbeat(const std::string& sender_id) {
    return SimpleMessage(MessageType::HEARTBEAT, sender_id, "");
}

inline SimpleMessage createPortRequest(const std::string& sender_id, const std::string& service_name) {
    return SimpleMessage(MessageType::PORT_REQUEST, sender_id, service_name);
}

inline SimpleMessage createPortResponse(const std::string& sender_id, const std::string& port_info) {
    return SimpleMessage(MessageType::PORT_RESPONSE, sender_id, port_info);
}

inline SimpleMessage createDiscoveryAnnouncement(const std::string& sender_id, const std::string& service_info) {
    return SimpleMessage(MessageType::DISCOVERY_ANNOUNCEMENT, sender_id, service_info);
}

inline SimpleMessage createDataMessage(const std::string& sender_id, const std::string& data) {
    return SimpleMessage(MessageType::DATA_MESSAGE, sender_id, data);
}

} // namespace simple
} // namespace sgipc
